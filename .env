# ================================
# GUCCI MARKETPLACE - ENVIRONMENT
# ================================

# Port the server will listen on
PORT=3000

# Node environment: 'development' or 'production'
NODE_ENV=production

# Path to the SQLite database file
DATABASE_PATH=./marketplace.db

# Secret key used to sign session cookies (change this!)
SESSION_SECRET=change-this-to-a-long-random-string-before-going-live
